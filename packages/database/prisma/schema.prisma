generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  DEVELOPER
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  agents    Agent[]
  executions Execution[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Agent {
  id              String      @id @default(uuid())
  name            String
  description     String?
  owner           User        @relation(fields: [ownerId], references: [id])
  ownerId         String
  wallet          Wallet?
  reputation      Reputation?
  reputationScore Float       @default(50.0)
  services        Service[]   // Services published by this agent (if developer)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([ownerId])
  @@index([reputationScore])
}

model Service {
  id              String           @id @default(uuid())
  provider        Agent            @relation(fields: [providerId], references: [id])
  providerId      String
  name            String
  description     String
  categoryName    String
  category        ServiceCategory  @relation(fields: [categoryName], references: [name])
  endpoint        String
  price           Float            @default(0.0) // Price in AXC
  status          String           @default("ACTIVE")
  paymentRequired Boolean          @default(true)
  rating          Float            @default(0.0)
  usageCount      Int              @default(0)
  analytics       ServiceAnalytics?
  receipts        PaymentReceipt[]
  steps           ExecutionStep[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([categoryName])
  @@index([status])
  @@index([price])
}

model ServiceCategory {
  id       String    @id @default(uuid())
  name     String    @unique
  services Service[]
}

model ServiceAnalytics {
  id              String  @id @default(uuid())
  service         Service @relation(fields: [serviceId], references: [id])
  serviceId       String  @unique
  totalCalls      Int     @default(0)
  successfulCalls Int     @default(0)
  revenue         Float   @default(0.0)
  updatedAt       DateTime @updatedAt
}

model Wallet {
  id            String        @id @default(uuid())
  agent         Agent         @relation(fields: [agentId], references: [id])
  agentId       String        @unique
  balance       Float         @default(0.0)
  currency      String        @default("AXC")
  sentTransactions     Transaction[] @relation("SenderWallet")
  receivedTransactions Transaction[] @relation("ReceiverWallet")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum TransactionType {
  SERVICE_PAYMENT
  TOP_UP
  REFUND
}

model Transaction {
  id               String            @id @default(uuid())
  senderWallet     Wallet            @relation("SenderWallet", fields: [senderWalletId], references: [id])
  senderWalletId   String
  receiverWallet   Wallet            @relation("ReceiverWallet", fields: [receiverWalletId], references: [id])
  receiverWalletId String
  amount           Float
  currency         String            @default("AXC")
  status           TransactionStatus @default(PENDING)
  type             TransactionType
  receipt          PaymentReceipt?
  createdAt        DateTime          @default(now())

  @@index([createdAt])
  @@index([status])
  @@index([senderWalletId])
  @@index([receiverWalletId])
}

model PaymentReceipt {
  id            String      @id @default(uuid())
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  transactionId String      @unique
  service       Service?    @relation(fields: [serviceId], references: [id])
  serviceId     String?
  payer         String      // Agent ID or Wallet ID
  receiver      String      // Agent ID or Wallet ID
  amount        Float
  receiptHash   String
  used          Boolean     @default(false)
  createdAt     DateTime    @default(now())

  @@index([serviceId])
  @@index([payer])
  @@index([receiver])
}

model PaymentChallenge {
  id              String   @id @default(uuid())
  serviceId       String
  amount          Float
  currency        String   @default("AXC")
  recipientWallet String
  status          String   @default("PENDING") // PENDING, SETTLED, EXPIRED
  expiresAt       DateTime
  createdAt       DateTime @default(now())

  @@index([status])
  @@index([expiresAt])
}

model Reputation {
  id                     String   @id @default(uuid())
  agent                  Agent    @relation(fields: [agentId], references: [id])
  agentId                String   @unique
  successfulTransactions Int      @default(0)
  failedTransactions     Int      @default(0)
  score                  Float    @default(50.0)
  updatedAt              DateTime @updatedAt
}

model Execution {
  id          String          @id @default(uuid())
  goal        String
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  status      String          @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED
  totalCost   Float           @default(0.0)
  steps       ExecutionStep[]
  summary     String?
  result      Json?
  duration    Int?            // in milliseconds
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([userId])
  @@index([status])
}

model ExecutionStep {
  id              String    @id @default(uuid())
  execution       Execution @relation(fields: [executionId], references: [id])
  executionId     String
  capabilityName  String
  serviceId       String?
  service         Service?   @relation(fields: [serviceId], references: [id])
  providerAgentId String?
  status          String    @default("PENDING") // PENDING, PAID, EXECUTING, COMPLETED, FAILED
  cost            Float     @default(0.0)
  output          Json?
  error           String?
  transactionId   String?
  order           Int
  createdAt       DateTime  @default(now())

  @@index([executionId])
  @@index([serviceId])
}
